APP_NAME=eth-telegram-bot
DATABASE_BACKEND=firestore
DATABASE_URL=sqlite:///./trade_bot.db
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_firebase_project_id"}
FIRESTORE_COLLECTION_PREFIX=
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
SYMBOL=ETHUSDT
TIMEFRAME=15m
HIGHER_TIMEFRAME=4h
RISK_REWARD=2.0
MIN_SIGNAL_SCORE=3
SWING_ENABLED=true
SWING_TIMEFRAME=4h
SWING_HIGHER_TIMEFRAME=1d
SWING_RISK_REWARD=3.0
SWING_MIN_SIGNAL_SCORE=3
MAX_OPEN_TRADES_PER_TIMEFRAME=5
WINRATE_ALERT_THRESHOLD=45
TIMEZONE=Asia/Bangkok
SEND_SCAN_STATUS_WHEN_NO_SIGNAL=false
OPENAI_API_KEY=your_openai_api_key
OPENAI_TEXT_MODEL=gpt-4.1-mini
AI_TRADE_ANALYSIS_ENABLED=false
AI_MIN_CLOSED_TRADES=8
AI_ANALYSIS_LOOKBACK=30
